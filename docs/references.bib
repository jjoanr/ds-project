
@article{gerencser_push-sum_2019,
    title = {Push-{Sum} {With} {Transmission} {Failures}},
    volume = {64},
    issn = {1558-2523},
    url = {https://ieeexplore.ieee.org/document/8359298/},
    doi = {10.1109/TAC.2018.2836861},
    abstract = {The push-sum algorithm allows distributed computing of the
                average on a directed graph, and is particularly relevant when
                one is restricted to one-way and/or asynchronous communications.
                We investigate its behavior in the presence of unreliable
                communication channels where messages can be lost. We show that
                exponential convergence still holds and deduce fundamental
                properties that implicitly describe the distribution of the final
                value obtained. We analyze the error of the final common value we
                get for the essential case of two nodes, both theoretically and
                numerically. We provide performance comparison with a standard
                consensus algorithm.},
    number = {3},
    urldate = {2026-04-07},
    journal = {IEEE Transactions on Automatic Control},
    author = {Gerencsér, Balázs and Hendrickx, Julien M.},
    month = mar,
    year = {2019},
    keywords = {Asynchronous communication, automatic control, average consensus
                , Communication channels, Convergence, Current measurement,
                multi-agent systems, network theory (graphs), Optimization,
                packet loss, push-sum, Random variables, Standards},
    pages = {1019--1033},
    file = {Full Text PDF:/home/joanr/Zotero/storage/4XLPNSM9/Gerencsér and
            Hendrickx - 2019 - Push-Sum With Transmission
            Failures.pdf:application/pdf},
}

