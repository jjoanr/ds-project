    doi = {10.1109/SFCS.2003.1238221},
    abstract = {Over the last decade, we have seen a revolution in connectivity
                between computers, and a resulting paradigm shift from
                centralized to highly distributed systems. With massive scale
                also comes massive instability, as node and link failures become
